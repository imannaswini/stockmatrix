# ==============================================================================
# StockMatrix - Production-ready .gitignore
# Covers both Frontend (Vite/React) and Backend (Node.js/Express/MongoDB)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Dependencies
# ------------------------------------------------------------------------------
node_modules/
backend/node_modules/
frontend/node_modules/
.pnp
.pnp.js

# ------------------------------------------------------------------------------
# 2. Environment Variables & Secrets
# NEVER PUSH THESE FILES - Contains DB URIs, API Keys, etc.
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
*.pem

# ------------------------------------------------------------------------------
# 3. Production Builds & Compiled Output
# ------------------------------------------------------------------------------
/dist/
/build/
/out/
dist-ssr/
*.tsbuildinfo
.next/

# ------------------------------------------------------------------------------
# 4. Logs
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# 5. OS Generated Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# 6. IDEs and Editors
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.eclipse/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.local

# ------------------------------------------------------------------------------
# 7. Testing & Coverage
# ------------------------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------------------------
# 8. Caches & Temporary Files
# ------------------------------------------------------------------------------
.npm/
.eslintcache
.stylelintcache
.vite/
.tmp/
tmp/
*.tmp
*.temp
